# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_KEY=dev-api-key-change-in-production

# ── PostgreSQL + TimescaleDB ──────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password
POSTGRES_DB=ims_db
DATABASE_URL=postgresql+asyncpg://ims_user:ims_password@postgres:5432/ims_db

# ── MongoDB ───────────────────────────────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=ims_user
MONGO_PASSWORD=ims_password
MONGO_DB=ims_db
MONGO_URL=mongodb://ims_user:ims_password@mongo:27017/ims_db?authSource=admin

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Queue ─────────────────────────────────────────────────────
QUEUE_MAX_SIZE=50000
WORKER_COUNT=8

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_INGEST=1000
RATE_LIMIT_MANAGEMENT=100
RATE_LIMIT_WINDOW_SECONDS=1

# ── Debounce ──────────────────────────────────────────────────
DEBOUNCE_WINDOW_SECONDS=10
DEBOUNCE_THRESHOLD=100

# ── Circuit Breaker ───────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=30

# ── Observability ─────────────────────────────────────────────
METRICS_INTERVAL_SECONDS=5
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost